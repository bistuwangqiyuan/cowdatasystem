{
  "name": "cowdatasystem",
  "version": "1.0.0",
  "description": "奶牛实验数据管理系统 - Cow Experiment Data Management System",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:prod": "playwright test tests/e2e/08-production.spec.ts --config=playwright.config.prod.ts",
    "test:prod:ui": "playwright test tests/e2e/08-production.spec.ts --config=playwright.config.prod.ts --ui",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write \"**/*.{js,ts,astro,json,md}\"",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset"
  },
  "keywords": [
    "cow",
    "dairy",
    "farming",
    "data-management",
    "jamstack",
    "astro",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@astrojs/netlify": "^5.0.0",
    "@astrojs/tailwind": "^5.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "astro": "^4.0.0",
    "chart.js": "^4.4.0",
    "nanostores": "^0.10.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@vitest/ui": "^1.0.0",
    "playwright": "^1.40.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "workbox-cli": "^7.0.0",
    "workbox-window": "^7.0.0"
  }
}

