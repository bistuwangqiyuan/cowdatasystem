---
/**
 * 数据分析页面
 */
export const prerender = false; // 服务器端渲染

import Layout from '@components/layout/Layout.astro';
import { getCows } from '@/services/cows.service';
import { getHealthRecords } from '@/services/health.service';
import { getMilkRecords } from '@/services/milk.service';
import { getBreedingRecords } from '@/services/breeding.service';
import { isAbnormalHealth } from '@/types/health.types';

// 获取统计数据
const { data: cows } = await getCows();
const { data: healthRecords } = await getHealthRecords();
const { data: milkRecords } = await getMilkRecords();
const { data: breedingRecords } = await getBreedingRecords();

// 计算统计数据
const totalCows = cows?.length || 0;
const activeCows = cows?.filter(c => c.status === 'active').length || 0;
const femaleCows = cows?.filter(c => c.gender === 'female' && c.status === 'active').length || 0;

const totalHealthRecords = healthRecords?.length || 0;
const abnormalHealthRecords = healthRecords?.filter(r => isAbnormalHealth(r)).length || 0;
const abnormalHealthRate = totalHealthRecords > 0 
  ? ((abnormalHealthRecords / totalHealthRecords) * 100).toFixed(1) 
  : '0.0';

const totalMilkRecords = milkRecords?.length || 0;
const totalMilkYield = milkRecords?.reduce((sum, r) => sum + r.milk_yield, 0) || 0;
const avgMilkYield = totalMilkRecords > 0 
  ? (totalMilkYield / totalMilkRecords).toFixed(1) 
  : '0.0';

const totalBreedings = breedingRecords?.length || 0;
const completedBreedings = breedingRecords?.filter(r => r.status === 'completed').length || 0;
const breedingSuccessRate = totalBreedings > 0 
  ? ((completedBreedings / totalBreedings) * 100).toFixed(1) 
  : '0.0';

// 最近30天的产奶趋势数据
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const recentMilkRecords = milkRecords?.filter(r => 
  new Date(r.recorded_datetime) >= thirtyDaysAgo
) || [];

// 按日期分组
const dailyMilkData = new Map<string, number>();
recentMilkRecords.forEach(record => {
  const date = record.recorded_datetime.split('T')[0];
  dailyMilkData.set(date, (dailyMilkData.get(date) || 0) + record.milk_yield);
});

const milkTrendData = Array.from(dailyMilkData.entries())
  .sort((a, b) => a[0].localeCompare(b[0]))
  .slice(-7); // 最近7天

// 计算品种分布
const breedLabels = {
  holstein: '荷斯坦',
  jersey: '娟姗',
  other: '其他',
};

const breedMap = {};
if (cows) {
  cows.forEach(cow => {
    breedMap[cow.breed] = (breedMap[cow.breed] || 0) + 1;
  });
}

const breedDistribution = Object.entries(breedMap).map(([breed, count]) => {
  const numCount = Number(count);
  return {
    breed,
    count: numCount,
    label: breedLabels[breed] || breed,
    percentage: cows && cows.length > 0 ? ((numCount / cows.length) * 100).toFixed(1) : '0',
  };
});

// 计算状态分布
const statusLabels = {
  active: '在养',
  culled: '已淘汰',
  sold: '已售出',
  dead: '死亡',
};

const statusMap = {};
if (cows) {
  cows.forEach(cow => {
    statusMap[cow.status] = (statusMap[cow.status] || 0) + 1;
  });
}

const statusDistribution = Object.entries(statusMap).map(([status, count]) => {
  const numCount = Number(count);
  return {
    status,
    count: numCount,
    label: statusLabels[status] || status,
    percentage: cows && cows.length > 0 ? ((numCount / cows.length) * 100).toFixed(1) : '0',
    colorClass: status === 'active' ? 'bg-green-500' : 'bg-gray-400',
  };
});
---

<Layout title="数据分析">
  <div class="space-y-6">
    <!-- 页面头部 -->
    <div>
      <h1 class="text-2xl md:text-3xl font-bold">数据分析</h1>
      <p class="text-gray-600 mt-1">养殖场数据统计和分析</p>
    </div>

    <!-- 核心指标卡片 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- 奶牛总数 -->
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 text-white p-6 rounded-lg shadow-lg">
        <div class="text-sm opacity-90">奶牛总数</div>
        <div class="text-4xl font-bold mt-2">{totalCows}</div>
        <div class="text-sm opacity-75 mt-2">在养: {activeCows} 头</div>
      </div>

      <!-- 产奶量统计 -->
      <div class="bg-gradient-to-br from-green-500 to-green-600 text-white p-6 rounded-lg shadow-lg">
        <div class="text-sm opacity-90">总产奶量</div>
        <div class="text-4xl font-bold mt-2">{totalMilkYield.toFixed(0)}<span class="text-2xl">L</span></div>
        <div class="text-sm opacity-75 mt-2">平均: {avgMilkYield}L/次</div>
      </div>

      <!-- 健康监测 -->
      <div class="bg-gradient-to-br from-red-500 to-red-600 text-white p-6 rounded-lg shadow-lg">
        <div class="text-sm opacity-90">健康记录</div>
        <div class="text-4xl font-bold mt-2">{totalHealthRecords}</div>
        <div class="text-sm opacity-75 mt-2">异常率: {abnormalHealthRate}%</div>
      </div>

      <!-- 繁殖统计 -->
      <div class="bg-gradient-to-br from-purple-500 to-purple-600 text-white p-6 rounded-lg shadow-lg">
        <div class="text-sm opacity-90">繁殖记录</div>
        <div class="text-4xl font-bold mt-2">{totalBreedings}</div>
        <div class="text-sm opacity-75 mt-2">成功率: {breedingSuccessRate}%</div>
      </div>
    </div>

    <!-- 产奶趋势图表 -->
    <div class="bg-white p-6 rounded-lg shadow">
      <h2 class="text-xl font-semibold mb-4">近7天产奶趋势</h2>
      {milkTrendData.length > 0 ? (
        <div class="space-y-3">
          {milkTrendData.map(([date, yield_]) => {
            const maxYield = Math.max(...milkTrendData.map(d => d[1]));
            const percentage = (yield_ / maxYield) * 100;
            
            return (
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm text-gray-600">
                    {new Date(date).toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                  </span>
                  <span class="text-sm font-semibold text-green-600">
                    {yield_.toFixed(1)} L
                  </span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-4">
                  <div
                    class="bg-gradient-to-r from-green-400 to-green-600 h-4 rounded-full transition-all duration-300"
                    style={`width: ${percentage}%`}
                  ></div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p>暂无最近的产奶数据</p>
        </div>
      )}
    </div>

    <!-- 奶牛统计 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- 按品种统计 -->
      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4">按品种分布</h2>
        {breedDistribution.length > 0 ? (
          <div class="space-y-3">
            {breedDistribution.map((item) => (
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm">{item.label}</span>
                  <span class="text-sm font-semibold">{item.count} 头 ({item.percentage}%)</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3">
                  <div
                    class="bg-blue-500 h-3 rounded-full"
                    style={`width: ${item.percentage}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-8 text-gray-500">暂无数据</div>
        )}
      </div>

      <!-- 按状态统计 -->
      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold mb-4">按状态分布</h2>
        {statusDistribution.length > 0 ? (
          <div class="space-y-3">
            {statusDistribution.map((item) => (
              <div>
                <div class="flex justify-between items-center mb-1">
                  <span class="text-sm">{item.label}</span>
                  <span class="text-sm font-semibold">{item.count} 头 ({item.percentage}%)</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3">
                  <div
                    class={`${item.colorClass} h-3 rounded-full`}
                    style={`width: ${item.percentage}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-8 text-gray-500">暂无数据</div>
        )}
      </div>
    </div>

    <!-- 快速导航 -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <a href="/cows" class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition-shadow text-center">
        <div class="text-3xl mb-2">🐄</div>
        <div class="font-semibold">奶牛档案</div>
        <div class="text-sm text-gray-600 mt-1">{totalCows} 头</div>
      </a>
      <a href="/health" class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition-shadow text-center">
        <div class="text-3xl mb-2">🏥</div>
        <div class="font-semibold">健康记录</div>
        <div class="text-sm text-gray-600 mt-1">{totalHealthRecords} 条</div>
      </a>
      <a href="/milk" class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition-shadow text-center">
        <div class="text-3xl mb-2">🥛</div>
        <div class="font-semibold">产奶记录</div>
        <div class="text-sm text-gray-600 mt-1">{totalMilkRecords} 条</div>
      </a>
      <a href="/breeding" class="bg-white p-6 rounded-lg shadow hover:shadow-lg transition-shadow text-center">
        <div class="text-3xl mb-2">💑</div>
        <div class="font-semibold">繁殖管理</div>
        <div class="text-sm text-gray-600 mt-1">{totalBreedings} 条</div>
      </a>
    </div>
  </div>
</Layout>
