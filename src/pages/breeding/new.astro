---
/**
 * 添加繁殖记录页面
 */
export const prerender = false; // 服务器端渲染

import Layout from '@components/layout/Layout.astro';

const cowId = Astro.url.searchParams.get('cow_id') || undefined;
---

<Layout title="添加繁殖记录">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold">添加繁殖记录</h1>
      <p class="text-gray-600 mt-2">记录奶牛配种信息</p>
    </div>
    
    <div class="bg-white p-6 rounded-lg shadow">
      <form id="breeding-form" class="space-y-4">
        <!-- 奶牛选择 -->
        <div>
          <label for="cow_id" class="block text-sm font-medium mb-1">
            选择奶牛 <span class="text-red-500">*</span>
          </label>
          <select
            id="cow_id"
            name="cow_id"
            required
            class="w-full h-12 px-4 border rounded-lg"
          >
            <option value="">请选择奶牛</option>
          </select>
        </div>

        <!-- 配种日期 -->
        <div>
          <label for="breeding_date" class="block text-sm font-medium mb-1">
            配种日期 <span class="text-red-500">*</span>
          </label>
          <input
            type="date"
            id="breeding_date"
            name="breeding_date"
            required
            max={new Date().toISOString().split('T')[0]}
            class="w-full h-12 px-4 border rounded-lg"
          />
        </div>

        <!-- 配种方式 -->
        <div>
          <label class="block text-sm font-medium mb-1">
            配种方式 <span class="text-red-500">*</span>
          </label>
          <div class="flex gap-4">
            <label class="flex items-center">
              <input
                type="radio"
                name="breeding_method"
                value="artificial"
                checked
                required
                class="mr-2 w-5 h-5"
              />
              人工授精
            </label>
            <label class="flex items-center">
              <input
                type="radio"
                name="breeding_method"
                value="natural"
                class="mr-2 w-5 h-5"
              />
              自然交配
            </label>
          </div>
        </div>

        <!-- 备注 -->
        <div>
          <label for="notes" class="block text-sm font-medium mb-1">
            备注
          </label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            class="w-full px-4 py-2 border rounded-lg"
            placeholder="其他补充信息..."
          ></textarea>
        </div>

        <!-- 提交按钮 -->
        <div class="flex gap-4">
          <button
            type="submit"
            class="flex-1 min-h-[44px] bg-blue-600 text-white rounded-lg hover:bg-blue-700"
          >
            添加记录
          </button>
          <a
            href="/breeding"
            class="flex-1 min-h-[44px] flex items-center justify-center border border-gray-300 rounded-lg hover:bg-gray-50"
          >
            取消
          </a>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { createBreedingRecord } from '@/services/breeding.service';
  import { getCows } from '@/services/cows.service';

  const form = document.getElementById('breeding-form') as HTMLFormElement;
  const cowSelect = document.getElementById('cow_id') as HTMLSelectElement;

  // 加载母牛列表
  (async () => {
    const { data: cows } = await getCows({ status: 'active' });
    if (cows) {
      const femaleCows = cows.filter(cow => cow.gender === 'female');
      femaleCows.forEach(cow => {
        const option = document.createElement('option');
        option.value = cow.id;
        option.textContent = `${cow.cow_number} - ${cow.name || '未命名'}`;
        cowSelect.appendChild(option);
      });
    }
  })();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data: any = Object.fromEntries(formData);

    try {
      const result = await createBreedingRecord(data);
      if (result.error) throw result.error;
      alert('繁殖记录添加成功！');
      window.location.href = '/breeding';
    } catch (error: any) {
      alert(`操作失败：${error.message}`);
    }
  });
</script>
