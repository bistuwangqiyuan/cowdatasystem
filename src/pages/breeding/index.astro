---
/**
 * 繁殖管理页面
 */
import Layout from '@components/layout/Layout.astro';
import { getBreedingRecords } from '@/services/breeding.service';
import { BreedingStatusLabels, BreedingMethodLabels } from '@/types/breeding.types';

const { data: records, error } = await getBreedingRecords();

if (error) {
  console.error('Failed to load breeding records:', error);
}
---

<Layout title="繁殖管理">
  <div class="space-y-6">
    <!-- 页面头部 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">繁殖管理</h1>
        <p class="text-gray-600 mt-1">奶牛配种和妊娠记录管理</p>
      </div>
      <a
        href="/breeding/new"
        class="w-full md:w-auto min-h-[44px] px-6 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center justify-center"
      >
        + 添加繁殖记录
      </a>
    </div>

    <!-- 繁殖记录列表 -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      {records && records.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead class="bg-gray-100">
              <tr>
                <th class="px-4 py-3 text-left">配种日期</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">奶牛编号</th>
                <th class="px-4 py-3 text-left">配种方式</th>
                <th class="px-4 py-3 text-left">状态</th>
                <th class="px-4 py-3 text-left hidden lg:table-cell">预产期</th>
                <th class="px-4 py-3 text-center">操作</th>
              </tr>
            </thead>
            <tbody>
              {records.map((record) => (
                <tr class="border-b hover:bg-gray-50">
                  <td class="px-4 py-3">
                    {new Date(record.breeding_date).toLocaleDateString('zh-CN')}
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell font-medium">
                    -
                  </td>
                  <td class="px-4 py-3">
                    {BreedingMethodLabels[record.breeding_method]}
                  </td>
                  <td class="px-4 py-3">
                    <span class={`px-2 py-1 rounded text-sm ${
                      record.status === 'completed' ? 'bg-green-100 text-green-800' :
                      record.status === 'failed' ? 'bg-red-100 text-red-800' :
                      'bg-blue-100 text-blue-800'
                    }`}>
                      {BreedingStatusLabels[record.status]}
                    </span>
                  </td>
                  <td class="px-4 py-3 hidden lg:table-cell">
                    {record.expected_calving_date ? 
                      new Date(record.expected_calving_date).toLocaleDateString('zh-CN') : 
                      '-'}
                  </td>
                  <td class="px-4 py-3 text-center">
                    <a
                      href={`/breeding/${record.id}`}
                      class="inline-block px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700"
                    >
                      详情
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p class="text-lg mb-2">暂无繁殖记录</p>
          <a href="/breeding/new" class="text-blue-600 hover:underline">
            点击添加第一条记录
          </a>
        </div>
      )}
    </div>

    <!-- 统计信息 -->
    {records && records.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">总配种数</div>
          <div class="text-2xl font-bold text-blue-600">{records.length}</div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">已完成</div>
          <div class="text-2xl font-bold text-green-600">
            {records.filter(r => r.status === 'completed').length}
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">待产</div>
          <div class="text-2xl font-bold text-purple-600">
            {records.filter(r => r.expected_calving_date && !r.actual_calving_date).length}
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>
