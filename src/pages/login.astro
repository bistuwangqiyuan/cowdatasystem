---
/**
 * Login Page
 * 
 * 用户登录页面，支持邮箱密码登录。
 * 使用 Supabase Auth 进行身份验证。
 */

import Layout from '@components/layout/Layout.astro';
---

<Layout title="登录" description="登录奶牛数据管理系统">
  <div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <!-- 登录卡片 -->
      <div class="bg-white rounded-2xl shadow-xl p-8">
        <!-- Logo & Title -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-gray-900">欢迎回来</h1>
          <p class="text-gray-600 mt-2">登录到奶牛数据管理系统</p>
        </div>

        <!-- 登录表单 -->
        <form id="login-form" class="space-y-6">
          <!-- 邮箱 -->
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              邮箱地址
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="your@example.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="email"
            />
          </div>

          <!-- 密码 -->
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              密码
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="••••••••"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="current-password"
            />
          </div>

          <!-- 记住我 & 忘记密码 -->
          <div class="flex items-center justify-between">
            <label class="flex items-center">
              <input
                type="checkbox"
                id="remember"
                class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
              />
              <span class="ml-2 text-sm text-gray-600">记住我</span>
            </label>
            <a href="/forgot-password" class="text-sm text-primary-600 hover:text-primary-700">
              忘记密码？
            </a>
          </div>

          <!-- 错误提示 -->
          <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <!-- 错误信息将在此显示 -->
          </div>

          <!-- 登录按钮 -->
          <button
            type="submit"
            id="login-btn"
            class="w-full bg-primary-600 text-white py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            登录
          </button>
        </form>

        <!-- 注册链接 -->
        <p class="text-center text-sm text-gray-600 mt-6">
          还没有账号？
          <a href="/register" class="text-primary-600 hover:text-primary-700 font-semibold">
            立即注册
          </a>
        </p>
      </div>

      <!-- 帮助链接 -->
      <div class="text-center mt-6">
        <a href="/" class="text-sm text-gray-600 hover:text-gray-900">
          ← 返回首页
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 输入框聚焦动画 */
  input:focus {
    outline: none;
  }
  
  /* 自定义主色调 */
  :global(.text-primary-600) {
    color: #2563eb;
  }
  
  :global(.text-primary-700) {
    color: #1d4ed8;
  }
  
  :global(.bg-primary-100) {
    background-color: #dbeafe;
  }
  
  :global(.bg-primary-600) {
    background-color: #2563eb;
  }
  
  :global(.bg-primary-700) {
    background-color: #1d4ed8;
  }
  
  :global(.border-primary-500) {
    border-color: #3b82f6;
  }
  
  :global(.ring-primary-500) {
    --tw-ring-color: #3b82f6;
  }
  
  :global(.hover\:bg-primary-700:hover) {
    background-color: #1d4ed8;
  }
  
  :global(.hover\:text-primary-700:hover) {
    color: #1d4ed8;
  }
  
  :global(.focus\:ring-primary-500:focus) {
    --tw-ring-color: #3b82f6;
  }
  
  /* 加载状态 */
  .loading {
    opacity: 0.6;
    pointer-events: none;
  }
</style>

<script>
  import { signIn } from '@/lib/auth';
  
  const form = document.getElementById('login-form') as HTMLFormElement;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  
  // 表单提交处理
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // 获取表单数据
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    
    // 隐藏错误提示
    errorMessage?.classList.add('hidden');
    
    // 显示加载状态
    loginBtn.classList.add('loading');
    loginBtn.textContent = '登录中...';
    
    try {
      // 调用登录函数
      const { data, error } = await signIn(email, password);
      
      if (error) {
        throw new Error(error.message || '登录失败');
      }
      
      // 登录成功，跳转到主页或上一页
      console.log('[Login] Success:', data);
      const returnUrl = new URLSearchParams(window.location.search).get('returnUrl') || '/cows';
      window.location.href = returnUrl;
      
    } catch (error: any) {
      // 显示错误信息
      console.error('[Login] Error:', error);
      errorMessage.textContent = error.message || '登录失败，请检查邮箱和密码';
      errorMessage.classList.remove('hidden');
      
      // 恢复按钮状态
      loginBtn.classList.remove('loading');
      loginBtn.textContent = '登录';
    }
  });
  
  // 自动聚焦到邮箱输入框
  const emailInput = document.getElementById('email') as HTMLInputElement;
  emailInput?.focus();
</script>

