---
/**
 * 健康记录列表页面
 */
export const prerender = false; // 服务器端渲染

import Layout from '@components/layout/Layout.astro';
import { getHealthRecords } from '@/services/health.service';
import { isAbnormalHealth, getTemperatureStatus } from '@/types/health.types';

// 获取查询参数
const cowId = Astro.url.searchParams.get('cow_id');
const abnormalOnly = Astro.url.searchParams.get('abnormal') === 'true';

// 获取健康记录
const { data: records, error } = await getHealthRecords({
  cow_id: cowId || undefined,
  abnormal_only: abnormalOnly,
});

if (error) {
  console.error('Failed to load health records:', error);
}

const mentalStateLabels: Record<string, string> = {
  normal: '正常',
  depressed: '沉郁',
  excited: '兴奋',
};

const appetiteLabels: Record<string, string> = {
  good: '良好',
  normal: '一般',
  poor: '较差',
};
---

<Layout title="健康记录">
  <div class="space-y-6">
    <!-- 页面头部 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">健康记录管理</h1>
        <p class="text-gray-600 mt-1">奶牛日常健康监测数据</p>
      </div>
      <a
        href="/health/new"
        class="w-full md:w-auto min-h-[44px] px-6 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center justify-center"
      >
        + 添加健康记录
      </a>
    </div>

    <!-- 筛选栏 -->
    <div class="bg-white p-4 rounded-lg shadow">
      <form method="get" class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
          <label class="flex items-center">
            <input
              type="checkbox"
              name="abnormal"
              value="true"
              checked={abnormalOnly}
              class="mr-2 w-5 h-5"
            />
            仅显示异常记录
          </label>
        </div>
        <button
          type="submit"
          class="min-w-[80px] min-h-[44px] bg-gray-600 text-white rounded-lg hover:bg-gray-700"
        >
          筛选
        </button>
        <a
          href="/health"
          class="min-w-[80px] min-h-[44px] flex items-center justify-center border border-gray-300 rounded-lg hover:bg-gray-50"
        >
          重置
        </a>
      </form>
    </div>

    <!-- 健康记录列表 -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      {records && records.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead class="bg-gray-100">
              <tr>
                <th class="px-4 py-3 text-left">检查时间</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">奶牛编号</th>
                <th class="px-4 py-3 text-left">体温</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">精神状态</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">食欲</th>
                <th class="px-4 py-3 text-left">状态</th>
                <th class="px-4 py-3 text-center">操作</th>
              </tr>
            </thead>
            <tbody>
              {records.map((record) => {
                const isAbnormal = isAbnormalHealth(record);
                const tempStatus = getTemperatureStatus(record.temperature);
                
                return (
                  <tr class="border-b hover:bg-gray-50">
                    <td class="px-4 py-3">
                      {new Date(record.check_datetime).toLocaleString('zh-CN', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit',
                      })}
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell font-medium">
                      {/* 显示奶牛编号，需要关联查询 */}
                      -
                    </td>
                    <td class="px-4 py-3">
                      <span class={`font-medium ${
                        tempStatus === 'normal' ? 'text-green-600' : 'text-red-600'
                      }`}>
                        {record.temperature}°C
                      </span>
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                      {mentalStateLabels[record.mental_state]}
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                      {appetiteLabels[record.appetite]}
                    </td>
                    <td class="px-4 py-3">
                      {isAbnormal ? (
                        <span class="px-2 py-1 bg-red-100 text-red-800 rounded text-sm">
                          异常
                        </span>
                      ) : (
                        <span class="px-2 py-1 bg-green-100 text-green-800 rounded text-sm">
                          正常
                        </span>
                      )}
                    </td>
                    <td class="px-4 py-3 text-center">
                      <a
                        href={`/health/${record.id}`}
                        class="inline-block px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700"
                      >
                        详情
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p class="text-lg mb-2">暂无健康记录</p>
          <a href="/health/new" class="text-blue-600 hover:underline">
            点击添加第一条记录
          </a>
        </div>
      )}
    </div>

    <!-- 统计信息 -->
    {records && records.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">总记录数</div>
          <div class="text-2xl font-bold text-blue-600">{records.length}</div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">异常记录</div>
          <div class="text-2xl font-bold text-red-600">
            {records.filter(r => isAbnormalHealth(r)).length}
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">平均体温</div>
          <div class="text-2xl font-bold text-green-600">
            {(records.reduce((sum, r) => sum + r.temperature, 0) / records.length).toFixed(1)}°C
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>
