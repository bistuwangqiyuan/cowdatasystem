---
/**
 * 添加健康记录页面
 */
import Layout from '@components/layout/Layout.astro';
import HealthRecordForm from '@components/forms/HealthRecordForm.astro';

const cowId = Astro.url.searchParams.get('cow_id') || undefined;
---

<Layout title="添加健康记录">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold">添加健康记录</h1>
      <p class="text-gray-600 mt-2">记录奶牛的日常健康检查数据</p>
    </div>
    
    <div class="bg-white p-6 rounded-lg shadow">
      <HealthRecordForm mode="create" cowId={cowId} />
    </div>
  </div>
</Layout>
