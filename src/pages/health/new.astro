---
/**
 * New Health Record Page
 * 
 * 新增健康记录页面。
 */

import Layout from '@components/layout/Layout.astro';
import HealthRecordForm from '@components/forms/HealthRecordForm.astro';

export const prerender = false;

const cowId = Astro.url.searchParams.get('cow_id');
---

<Layout title="添加健康记录">
  <div class="max-w-4xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">添加健康记录</h1>
      <p class="text-gray-600 mt-1">记录奶牛的健康状况</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
      <HealthRecordForm mode="create" cowId={cowId || undefined} />
    </div>
  </div>
</Layout>

