---
/**
 * 产奶记录列表页面
 */
import Layout from '@components/layout/Layout.astro';
import { getMilkRecords } from '@/services/milk.service';
import { MilkingSessionLabels, isAbnormalSomaticCellCount } from '@/types/milk.types';

// 获取查询参数
const cowId = Astro.url.searchParams.get('cow_id');
const session = Astro.url.searchParams.get('session');
const abnormalOnly = Astro.url.searchParams.get('abnormal') === 'true';

// 获取产奶记录
const { data: records, error } = await getMilkRecords({
  cow_id: cowId || undefined,
  milking_session: session as any,
  abnormal_only: abnormalOnly,
});

if (error) {
  console.error('Failed to load milk records:', error);
}
---

<Layout title="产奶记录">
  <div class="space-y-6">
    <!-- 页面头部 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">产奶记录管理</h1>
        <p class="text-gray-600 mt-1">奶牛挤奶产量和质量数据</p>
      </div>
      <a
        href="/milk/new"
        class="w-full md:w-auto min-h-[44px] px-6 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center justify-center"
      >
        + 添加产奶记录
      </a>
    </div>

    <!-- 筛选栏 -->
    <div class="bg-white p-4 rounded-lg shadow">
      <form method="get" class="flex flex-col md:flex-row gap-4">
        <div class="flex-1">
          <label for="session" class="block text-sm font-medium mb-1">挤奶时段</label>
          <select
            id="session"
            name="session"
            class="w-full h-12 px-4 border rounded-lg"
          >
            <option value="">全部时段</option>
            <option value="morning" selected={session === 'morning'}>早班</option>
            <option value="afternoon" selected={session === 'afternoon'}>午班</option>
            <option value="evening" selected={session === 'evening'}>晚班</option>
          </select>
        </div>
        <div class="flex-1 flex items-end">
          <label class="flex items-center">
            <input
              type="checkbox"
              name="abnormal"
              value="true"
              checked={abnormalOnly}
              class="mr-2 w-5 h-5"
            />
            仅显示异常记录
          </label>
        </div>
        <div class="flex gap-2">
          <button
            type="submit"
            class="min-w-[80px] min-h-[44px] bg-gray-600 text-white rounded-lg hover:bg-gray-700"
          >
            筛选
          </button>
          <a
            href="/milk"
            class="min-w-[80px] min-h-[44px] flex items-center justify-center border border-gray-300 rounded-lg hover:bg-gray-50"
          >
            重置
          </a>
        </div>
      </form>
    </div>

    <!-- 产奶记录列表 -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      {records && records.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead class="bg-gray-100">
              <tr>
                <th class="px-4 py-3 text-left">挤奶时间</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">奶牛编号</th>
                <th class="px-4 py-3 text-left">时段</th>
                <th class="px-4 py-3 text-left">产量(L)</th>
                <th class="px-4 py-3 text-left hidden md:table-cell">脂肪率</th>
                <th class="px-4 py-3 text-left hidden lg:table-cell">蛋白质率</th>
                <th class="px-4 py-3 text-left hidden lg:table-cell">体细胞数</th>
                <th class="px-4 py-3 text-center">操作</th>
              </tr>
            </thead>
            <tbody>
              {records.map((record) => {
                const isSCCAbnormal = isAbnormalSomaticCellCount(record.somatic_cell_count);
                
                return (
                  <tr class="border-b hover:bg-gray-50">
                    <td class="px-4 py-3">
                      {new Date(record.recorded_datetime).toLocaleString('zh-CN', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit',
                      })}
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell font-medium">
                      -
                    </td>
                    <td class="px-4 py-3">
                      <span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-sm">
                        {MilkingSessionLabels[record.milking_session]}
                      </span>
                    </td>
                    <td class="px-4 py-3 font-semibold text-green-600">
                      {record.milk_yield}
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                      {record.fat_percentage ? `${record.fat_percentage}%` : '-'}
                    </td>
                    <td class="px-4 py-3 hidden lg:table-cell">
                      {record.protein_percentage ? `${record.protein_percentage}%` : '-'}
                    </td>
                    <td class="px-4 py-3 hidden lg:table-cell">
                      {record.somatic_cell_count ? (
                        <span class={isSCCAbnormal ? 'text-red-600 font-medium' : ''}>
                          {record.somatic_cell_count}
                        </span>
                      ) : '-'}
                    </td>
                    <td class="px-4 py-3 text-center">
                      <a
                        href={`/milk/${record.id}`}
                        class="inline-block px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700"
                      >
                        详情
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-12 text-gray-500">
          <p class="text-lg mb-2">暂无产奶记录</p>
          <a href="/milk/new" class="text-blue-600 hover:underline">
            点击添加第一条记录
          </a>
        </div>
      )}
    </div>

    <!-- 统计信息 -->
    {records && records.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">总记录数</div>
          <div class="text-2xl font-bold text-blue-600">{records.length}</div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">总产奶量</div>
          <div class="text-2xl font-bold text-green-600">
            {records.reduce((sum, r) => sum + r.milk_yield, 0).toFixed(1)}L
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">平均产量</div>
          <div class="text-2xl font-bold text-purple-600">
            {(records.reduce((sum, r) => sum + r.milk_yield, 0) / records.length).toFixed(1)}L
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">异常记录</div>
          <div class="text-2xl font-bold text-red-600">
            {records.filter(r => isAbnormalSomaticCellCount(r.somatic_cell_count)).length}
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>
