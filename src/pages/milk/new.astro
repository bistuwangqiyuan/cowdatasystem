---
/**
 * 添加产奶记录页面
 */
export const prerender = false; // 服务器端渲染

import Layout from '@components/layout/Layout.astro';
import MilkRecordForm from '@components/forms/MilkRecordForm.astro';

const cowId = Astro.url.searchParams.get('cow_id') || undefined;
---

<Layout title="添加产奶记录">
  <div class="max-w-2xl mx-auto">
    <div class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold">添加产奶记录</h1>
      <p class="text-gray-600 mt-2">记录奶牛的挤奶产量和质量数据</p>
    </div>
    
    <div class="bg-white p-6 rounded-lg shadow">
      <MilkRecordForm mode="create" cowId={cowId} />
    </div>
  </div>
</Layout>
