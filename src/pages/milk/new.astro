---
/**
 * New Milk Record Page
 * 
 * 新增产奶记录页面。
 */

import Layout from '@components/layout/Layout.astro';
import MilkRecordForm from '@components/forms/MilkRecordForm.astro';

export const prerender = false;

const cowId = Astro.url.searchParams.get('cow_id');
---

<Layout title="添加产奶记录">
  <div class="max-w-4xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">添加产奶记录</h1>
      <p class="text-gray-600 mt-1">记录奶牛的产奶数据</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
      <MilkRecordForm mode="create" cowId={cowId || undefined} />
    </div>
  </div>
</Layout>

