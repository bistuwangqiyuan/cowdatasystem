---
/**
 * 饲料管理页面
 */
export const prerender = false; // 服务器端渲染

import Layout from '@components/layout/Layout.astro';
import { getFeedFormulas, getFeedingRecords } from '@/services/feed.service';

const activeTab = Astro.url.searchParams.get('tab') || 'formulas';

const { data: formulas } = await getFeedFormulas();
const { data: records } = await getFeedingRecords();
---

<Layout title="饲料管理">
  <div class="space-y-6">
    <!-- 页面头部 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold">饲料管理</h1>
        <p class="text-gray-600 mt-1">饲料配方和投喂记录管理</p>
      </div>
      <div class="flex gap-2">
        <a
          href="/feed/formula/new"
          class="min-h-[44px] px-6 bg-green-600 text-white rounded-lg hover:bg-green-700 flex items-center justify-center"
        >
          + 新建配方
        </a>
        <a
          href="/feed/feeding/new"
          class="min-h-[44px] px-6 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center justify-center"
        >
          + 添加投喂记录
        </a>
      </div>
    </div>

    <!-- 标签页 -->
    <div class="bg-white rounded-lg shadow">
      <div class="border-b">
        <nav class="flex">
          <a
            href="/feed?tab=formulas"
            class={`px-6 py-3 border-b-2 font-medium ${
              activeTab === 'formulas' 
                ? 'border-blue-600 text-blue-600' 
                : 'border-transparent text-gray-600 hover:text-gray-800'
            }`}
          >
            饲料配方
          </a>
          <a
            href="/feed?tab=records"
            class={`px-6 py-3 border-b-2 font-medium ${
              activeTab === 'records' 
                ? 'border-blue-600 text-blue-600' 
                : 'border-transparent text-gray-600 hover:text-gray-800'
            }`}
          >
            投喂记录
          </a>
        </nav>
      </div>

      <div class="p-6">
        {activeTab === 'formulas' ? (
          <!-- 饲料配方列表 -->
          <div>
            {formulas && formulas.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {formulas.map((formula) => (
                  <div class="border rounded-lg p-4 hover:shadow-md transition-shadow">
                    <h3 class="font-semibold text-lg mb-2">{formula.formula_name}</h3>
                    <p class="text-sm text-gray-600 mb-2">编号: {formula.formula_code}</p>
                    <p class="text-sm text-gray-600 mb-3">适用: {formula.target_group}</p>
                    {formula.total_cost_per_kg && (
                      <p class="text-sm text-green-600 font-medium mb-3">
                        成本: ¥{formula.total_cost_per_kg}/kg
                      </p>
                    )}
                    <a
                      href={`/feed/formula/${formula.id}`}
                      class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm"
                    >
                      查看详情
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="text-center py-12 text-gray-500">
                <p class="text-lg mb-2">暂无饲料配方</p>
                <a href="/feed/formula/new" class="text-blue-600 hover:underline">
                  点击创建第一个配方
                </a>
              </div>
            )}
          </div>
        ) : (
          <!-- 投喂记录列表 -->
          <div>
            {records && records.length > 0 ? (
              <div class="overflow-x-auto">
                <table class="w-full border-collapse">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-4 py-3 text-left">投喂时间</th>
                      <th class="px-4 py-3 text-left hidden md:table-cell">奶牛编号</th>
                      <th class="px-4 py-3 text-left">饲料配方</th>
                      <th class="px-4 py-3 text-left">投喂量(kg)</th>
                      <th class="px-4 py-3 text-center">操作</th>
                    </tr>
                  </thead>
                  <tbody>
                    {records.map((record) => (
                      <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-3">
                          {new Date(record.feeding_datetime).toLocaleString('zh-CN')}
                        </td>
                        <td class="px-4 py-3 hidden md:table-cell">-</td>
                        <td class="px-4 py-3">-</td>
                        <td class="px-4 py-3 font-semibold">{record.quantity_kg}</td>
                        <td class="px-4 py-3 text-center">
                          <a
                            href={`/feed/feeding/${record.id}`}
                            class="inline-block px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700"
                          >
                            详情
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="text-center py-12 text-gray-500">
                <p class="text-lg mb-2">暂无投喂记录</p>
                <a href="/feed/feeding/new" class="text-blue-600 hover:underline">
                  点击添加第一条记录
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- 统计信息 -->
    {activeTab === 'formulas' && formulas && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">配方总数</div>
          <div class="text-2xl font-bold text-blue-600">{formulas.length}</div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">启用配方</div>
          <div class="text-2xl font-bold text-green-600">
            {formulas.filter(f => f.is_active).length}
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">平均成本</div>
          <div class="text-2xl font-bold text-purple-600">
            ¥{formulas.filter(f => f.total_cost_per_kg).length > 0 
              ? (formulas.reduce((sum, f) => sum + (f.total_cost_per_kg || 0), 0) / 
                 formulas.filter(f => f.total_cost_per_kg).length).toFixed(2)
              : '0.00'}/kg
          </div>
        </div>
      </div>
    )}

    {activeTab === 'records' && records && records.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">投喂次数</div>
          <div class="text-2xl font-bold text-blue-600">{records.length}</div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">总投喂量</div>
          <div class="text-2xl font-bold text-green-600">
            {records.reduce((sum, r) => sum + r.quantity_kg, 0).toFixed(1)}kg
          </div>
        </div>
        <div class="bg-white p-4 rounded-lg shadow">
          <div class="text-sm text-gray-600">平均投喂量</div>
          <div class="text-2xl font-bold text-purple-600">
            {(records.reduce((sum, r) => sum + r.quantity_kg, 0) / records.length).toFixed(1)}kg
          </div>
        </div>
      </div>
    )}
  </div>
</Layout>
