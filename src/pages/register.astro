---
/**
 * Register Page
 * 
 * 用户注册页面，支持邮箱密码注册。
 * 使用 Supabase Auth 进行身份验证。
 */

import Layout from '@components/layout/Layout.astro';
---

<Layout title="注册" description="注册奶牛数据管理系统账号">
  <div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <!-- 注册卡片 -->
      <div class="bg-white rounded-2xl shadow-xl p-8">
        <!-- Logo & Title -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-100 rounded-full mb-4">
            <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-gray-900">创建账号</h1>
          <p class="text-gray-600 mt-2">注册奶牛数据管理系统</p>
        </div>

        <!-- 注册表单 -->
        <form id="register-form" class="space-y-6">
          <!-- 姓名 -->
          <div>
            <label for="fullName" class="block text-sm font-medium text-gray-700 mb-2">
              姓名
            </label>
            <input
              type="text"
              id="fullName"
              name="fullName"
              required
              placeholder="请输入您的姓名"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="name"
            />
          </div>

          <!-- 邮箱 -->
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              邮箱地址
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="your@example.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="email"
            />
          </div>

          <!-- 密码 -->
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              密码
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="至少8个字符"
              minlength="8"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="new-password"
            />
            <p class="text-xs text-gray-500 mt-1">密码至少8个字符，建议包含字母和数字</p>
          </div>

          <!-- 确认密码 -->
          <div>
            <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">
              确认密码
            </label>
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              required
              placeholder="再次输入密码"
              minlength="8"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
              autocomplete="new-password"
            />
          </div>

          <!-- 服务条款 -->
          <div class="flex items-start">
            <input
              type="checkbox"
              id="terms"
              required
              class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500 mt-1"
            />
            <label for="terms" class="ml-2 text-sm text-gray-600">
              我已阅读并同意
              <a href="/terms" class="text-primary-600 hover:text-primary-700">服务条款</a>
              和
              <a href="/privacy" class="text-primary-600 hover:text-primary-700">隐私政策</a>
            </label>
          </div>

          <!-- 成功提示 -->
          <div id="success-message" class="hidden bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
            <!-- 成功信息将在此显示 -->
          </div>

          <!-- 错误提示 -->
          <div id="error-message" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
            <!-- 错误信息将在此显示 -->
          </div>

          <!-- 注册按钮 -->
          <button
            type="submit"
            id="register-btn"
            class="w-full bg-primary-600 text-white py-3 rounded-lg font-semibold hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
          >
            创建账号
          </button>
        </form>

        <!-- 登录链接 -->
        <p class="text-center text-sm text-gray-600 mt-6">
          已有账号？
          <a href="/login" class="text-primary-600 hover:text-primary-700 font-semibold">
            立即登录
          </a>
        </p>
      </div>

      <!-- 帮助链接 -->
      <div class="text-center mt-6">
        <a href="/" class="text-sm text-gray-600 hover:text-gray-900">
          ← 返回首页
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 输入框聚焦动画 */
  input:focus {
    outline: none;
  }
  
  /* 自定义主色调 */
  :global(.text-primary-600) {
    color: #2563eb;
  }
  
  :global(.text-primary-700) {
    color: #1d4ed8;
  }
  
  :global(.bg-primary-100) {
    background-color: #dbeafe;
  }
  
  :global(.bg-primary-600) {
    background-color: #2563eb;
  }
  
  :global(.bg-primary-700) {
    background-color: #1d4ed8;
  }
  
  :global(.border-primary-500) {
    border-color: #3b82f6;
  }
  
  :global(.ring-primary-500) {
    --tw-ring-color: #3b82f6;
  }
  
  :global(.hover\:bg-primary-700:hover) {
    background-color: #1d4ed8;
  }
  
  :global(.hover\:text-primary-700:hover) {
    color: #1d4ed8;
  }
  
  :global(.focus\:ring-primary-500:focus) {
    --tw-ring-color: #3b82f6;
  }
  
  /* 加载状态 */
  .loading {
    opacity: 0.6;
    pointer-events: none;
  }
  
  /* 密码强度指示器 */
  .password-strength {
    height: 4px;
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  
  .password-strength.weak {
    width: 33%;
    background-color: #ef4444;
  }
  
  .password-strength.medium {
    width: 66%;
    background-color: #f59e0b;
  }
  
  .password-strength.strong {
    width: 100%;
    background-color: #10b981;
  }
</style>

<script>
  import { signUp } from '@/lib/auth';
  
  const form = document.getElementById('register-form') as HTMLFormElement;
  const registerBtn = document.getElementById('register-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;
  
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement;
  
  // 密码强度检查
  passwordInput?.addEventListener('input', () => {
    const password = passwordInput.value;
    
    // 简单的密码强度检查
    let strength = 0;
    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
    if (/\d/.test(password)) strength++;
    if (/[!@#$%^&*(),.?":{}|<>]/.test(password)) strength++;
    
    // 更新强度指示器（可选实现）
  });
  
  // 确认密码匹配检查
  confirmPasswordInput?.addEventListener('input', () => {
    const password = passwordInput.value;
    const confirmPassword = confirmPasswordInput.value;
    
    if (confirmPassword && password !== confirmPassword) {
      confirmPasswordInput.setCustomValidity('两次输入的密码不一致');
    } else {
      confirmPasswordInput.setCustomValidity('');
    }
  });
  
  // 表单提交处理
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // 获取表单数据
    const formData = new FormData(form);
    const fullName = formData.get('fullName') as string;
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;
    
    // 验证密码匹配
    if (password !== confirmPassword) {
      errorMessage.textContent = '两次输入的密码不一致';
      errorMessage.classList.remove('hidden');
      return;
    }
    
    // 隐藏提示
    errorMessage?.classList.add('hidden');
    successMessage?.classList.add('hidden');
    
    // 显示加载状态
    registerBtn.classList.add('loading');
    registerBtn.textContent = '注册中...';
    
    try {
      // 调用注册函数
      const { data, error } = await signUp(email, password, fullName);
      
      if (error) {
        throw new Error(error.message || '注册失败');
      }
      
      // 注册成功
      console.log('[Register] Success:', data);
      
      // 显示成功消息
      successMessage.innerHTML = `
        <strong>注册成功！</strong><br>
        ${data.user?.email_confirmed_at 
          ? '正在跳转到登录页面...' 
          : '我们已向您的邮箱发送了一封确认邮件，请查收并点击链接激活账号。'}
      `;
      successMessage.classList.remove('hidden');
      
      // 如果邮箱已确认，3秒后跳转到登录页
      if (data.user?.email_confirmed_at) {
        setTimeout(() => {
          window.location.href = '/login';
        }, 3000);
      } else {
        // 5秒后跳转到登录页
        setTimeout(() => {
          window.location.href = '/login?message=请查收邮箱并激活账号';
        }, 5000);
      }
      
    } catch (error: any) {
      // 显示错误信息
      console.error('[Register] Error:', error);
      
      let errorMsg = '注册失败，请重试';
      
      // 友好的错误提示
      if (error.message.includes('User already registered')) {
        errorMsg = '该邮箱已被注册，请直接登录或使用其他邮箱';
      } else if (error.message.includes('Password')) {
        errorMsg = '密码强度不够，请使用至少8个字符的密码';
      } else if (error.message.includes('Email')) {
        errorMsg = '邮箱格式不正确，请检查后重试';
      } else if (error.message) {
        errorMsg = error.message;
      }
      
      errorMessage.textContent = errorMsg;
      errorMessage.classList.remove('hidden');
      
      // 恢复按钮状态
      registerBtn.classList.remove('loading');
      registerBtn.textContent = '创建账号';
    }
  });
  
  // 自动聚焦到姓名输入框
  const fullNameInput = document.getElementById('fullName') as HTMLInputElement;
  fullNameInput?.focus();
</script>

