---
/**
 * SEO Component
 * 
 * 统一管理页面的 SEO 元数据，包括：
 * - 基础 meta 标签（title, description, keywords）
 * - Open Graph（社交媒体分享）
 * - Twitter Card
 * - 结构化数据（JSON-LD）
 * - Canonical URL
 * 
 * 使用方法：
 * <SEO 
 *   title="页面标题" 
 *   description="页面描述"
 *   image="/og-image.jpg"
 *   type="website"
 * />
 */

export interface Props {
  /** 页面标题（50-60字符） */
  title: string;
  /** 页面描述（150-160字符） */
  description?: string;
  /** 关键词（可选） */
  keywords?: string;
  /** Open Graph 图片 URL */
  image?: string;
  /** Open Graph 类型 */
  type?: 'website' | 'article' | 'profile';
  /** 是否在标题后添加网站名称 */
  appendSiteName?: boolean;
  /** Canonical URL（规范链接） */
  canonical?: string;
  /** 是否允许搜索引擎索引 */
  noindex?: boolean;
  /** 是否允许搜索引擎跟踪链接 */
  nofollow?: boolean;
  /** 结构化数据（JSON-LD） */
  schema?: object;
  /** 文章发布时间（ISO 8601格式） */
  publishedTime?: string;
  /** 文章修改时间（ISO 8601格式） */
  modifiedTime?: string;
  /** 作者名称 */
  author?: string;
}

const {
  title,
  description = '现代化奶牛养殖数据管理系统，支持奶牛档案、健康监测、产奶记录、繁殖管理和数据分析。',
  keywords = '奶牛管理,养殖数据,健康监测,产奶记录,繁殖管理,数据分析',
  image = '/og-default.jpg',
  type = 'website',
  appendSiteName = true,
  canonical,
  noindex = false,
  nofollow = false,
  schema,
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

// 网站配置
const siteName = '奶牛数据管理系统';
const siteUrl = import.meta.env.SITE || 'https://cowdatasystem.netlify.app';
const twitterHandle = '@cowdatasystem'; // 根据实际情况修改

// 计算完整的标题
const fullTitle = appendSiteName ? `${title} - ${siteName}` : title;

// 计算完整的图片 URL
const fullImageUrl = image.startsWith('http') ? image : `${siteUrl}${image}`;

// 计算 Canonical URL
const fullCanonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;

// Robots meta 标签
const robotsContent = [
  noindex ? 'noindex' : 'index',
  nofollow ? 'nofollow' : 'follow',
].join(', ');

// 默认的结构化数据
const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description: '现代化奶牛养殖数据管理平台',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/cows?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

// 合并自定义 schema 和默认 schema
const finalSchema = schema || defaultSchema;
---

<!-- 基础 Meta 标签 -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />

<!-- Canonical URL -->
<link rel="canonical" href={fullCanonicalUrl} />

<!-- 语言和地区 -->
<link rel="alternate" hreflang="zh-CN" href={fullCanonicalUrl} />
<link rel="alternate" hreflang="x-default" href={fullCanonicalUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullCanonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="zh_CN" />

{publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{author && (
  <meta property="article:author" content={author} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullCanonicalUrl} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />

<!-- PWA / Mobile -->
<meta name="theme-color" content="#2563eb" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content={siteName} />
<meta name="application-name" content={siteName} />
<meta name="mobile-web-app-capable" content="yes" />

<!-- DNS Prefetch & Preconnect -->
<link rel="dns-prefetch" href={import.meta.env.SUPABASE_URL || 'https://supabase.co'} />
<link rel="preconnect" href={import.meta.env.SUPABASE_URL || 'https://supabase.co'} crossorigin />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Manifest -->
<link rel="manifest" href="/manifest.json" />

<!-- 结构化数据 (JSON-LD) -->
<script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

