---
/**
 * Layout Component
 * 
 * 基础页面布局组件，包含Header、主内容区和Footer。
 * 所有页面使用此布局以保持统一的视觉风格。
 */

import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '奶牛实验数据管理系统' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - 奶牛数据管理系统</title>
    
    <!-- Preconnect to Supabase -->
    <link rel="preconnect" href={import.meta.env.SUPABASE_URL} />
    
    <!-- Global Styles -->
    <link rel="stylesheet" href="/src/styles/global.css" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2563eb" />
    
    <!-- Mobile Optimization -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="奶牛管理" />
  </head>
  
  <body class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Header -->
    <Header />
    
    <!-- Main Content -->
    <main class="flex-1 container-app py-6">
      <slot />
    </main>
    
    <!-- Footer -->
    <Footer />
    
    <!-- Global Scripts -->
    <script>
      // 认证状态监听
      import { onAuthStateChange } from '@/lib/supabase';
      
      // 监听认证状态变化
      const unsubscribe = onAuthStateChange((event, session) => {
        if (event === 'SIGNED_OUT') {
          // 用户登出，跳转到登录页
          if (!window.location.pathname.includes('/login')) {
            window.location.href = '/login';
          }
        }
      });
      
      // 页面卸载时取消订阅
      window.addEventListener('beforeunload', () => {
        unsubscribe();
      });
    </script>
  </body>
</html>

<style>
  /* 页面过渡动画 */
  @view-transition {
    navigation: auto;
  }
  
  /* 移动端触控优化 */
  * {
    -webkit-tap-highlight-color: transparent;
  }
  
  /* 平滑滚动 */
  html {
    scroll-behavior: smooth;
  }
</style>

