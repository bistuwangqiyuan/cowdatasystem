---
/**
 * 产奶记录表单组件
 * 用于创建和编辑产奶记录
 */
import type { MilkRecord } from '@/types/milk.types';

interface Props {
  record?: MilkRecord;
  cowId?: string;
  mode: 'create' | 'edit';
}

const { record, cowId, mode } = Astro.props;
---

<form id="milk-record-form" class="space-y-4">
  <!-- 奶牛选择 (仅创建模式显示) -->
  {mode === 'create' && !cowId && (
    <div>
      <label for="cow_id" class="block text-sm font-medium mb-1">
        选择奶牛 <span class="text-red-500">*</span>
      </label>
      <select
        id="cow_id"
        name="cow_id"
        required
        class="w-full h-12 px-4 border rounded-lg"
      >
        <option value="">请选择奶牛</option>
        <!-- 奶牛列表将通过JavaScript动态加载 -->
      </select>
    </div>
  )}

  {(cowId || mode === 'edit') && (
    <input 
      type="hidden" 
      name="cow_id" 
      value={cowId || record?.cow_id} 
    />
  )}

  <!-- 记录日期时间 -->
  <div>
    <label for="recorded_datetime" class="block text-sm font-medium mb-1">
      挤奶时间 <span class="text-red-500">*</span>
    </label>
    <input
      type="datetime-local"
      id="recorded_datetime"
      name="recorded_datetime"
      value={record?.recorded_datetime?.slice(0, 16) || ''}
      max={new Date().toISOString().slice(0, 16)}
      required
      class="w-full h-12 px-4 border rounded-lg"
    />
  </div>

  <!-- 挤奶时段 -->
  <div>
    <label class="block text-sm font-medium mb-1">
      挤奶时段 <span class="text-red-500">*</span>
    </label>
    <div class="flex gap-4">
      <label class="flex items-center">
        <input
          type="radio"
          name="milking_session"
          value="morning"
          checked={record?.milking_session === 'morning' || !record}
          required
          class="mr-2 w-5 h-5"
        />
        早班
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="milking_session"
          value="afternoon"
          checked={record?.milking_session === 'afternoon'}
          class="mr-2 w-5 h-5"
        />
        午班
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="milking_session"
          value="evening"
          checked={record?.milking_session === 'evening'}
          class="mr-2 w-5 h-5"
        />
        晚班
      </label>
    </div>
  </div>

  <!-- 产奶量 -->
  <div>
    <label for="milk_yield" class="block text-sm font-medium mb-1">
      产奶量 (升) <span class="text-red-500">*</span>
    </label>
    <input
      type="number"
      id="milk_yield"
      name="milk_yield"
      value={record?.milk_yield || ''}
      step="0.1"
      min="0.1"
      required
      class="w-full h-12 px-4 border rounded-lg"
      placeholder="例如：25.5"
    />
  </div>

  <!-- 质量指标 -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- 脂肪率 -->
    <div>
      <label for="fat_percentage" class="block text-sm font-medium mb-1">
        脂肪率 (%)
      </label>
      <input
        type="number"
        id="fat_percentage"
        name="fat_percentage"
        value={record?.fat_percentage || ''}
        step="0.1"
        min="0"
        max="10"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 3.0-5.0"
      />
    </div>

    <!-- 蛋白质率 -->
    <div>
      <label for="protein_percentage" class="block text-sm font-medium mb-1">
        蛋白质率 (%)
      </label>
      <input
        type="number"
        id="protein_percentage"
        name="protein_percentage"
        value={record?.protein_percentage || ''}
        step="0.1"
        min="0"
        max="10"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 2.8-3.8"
      />
    </div>

    <!-- 乳糖含量 -->
    <div>
      <label for="lactose_percentage" class="block text-sm font-medium mb-1">
        乳糖含量 (%)
      </label>
      <input
        type="number"
        id="lactose_percentage"
        name="lactose_percentage"
        value={record?.lactose_percentage || ''}
        step="0.1"
        min="0"
        max="10"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 4.5-5.5"
      />
    </div>

    <!-- 体细胞数 -->
    <div>
      <label for="somatic_cell_count" class="block text-sm font-medium mb-1">
        体细胞数 (万个/mL)
      </label>
      <input
        type="number"
        id="somatic_cell_count"
        name="somatic_cell_count"
        value={record?.somatic_cell_count || ''}
        step="0.1"
        min="0"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: < 20"
      />
      <p class="text-xs text-gray-500 mt-1">超过20万/mL可能存在乳房炎</p>
    </div>
  </div>

  <!-- 备注 -->
  <div>
    <label for="notes" class="block text-sm font-medium mb-1">
      备注
    </label>
    <textarea
      id="notes"
      name="notes"
      rows="3"
      class="w-full px-4 py-2 border rounded-lg"
      placeholder="其他补充信息..."
    >{record?.notes || ''}</textarea>
  </div>

  <!-- 提交按钮 -->
  <div class="flex gap-4">
    <button
      type="submit"
      class="flex-1 min-h-[44px] bg-blue-600 text-white rounded-lg hover:bg-blue-700"
    >
      {mode === 'create' ? '添加记录' : '保存修改'}
    </button>
    <a
      href="/milk"
      class="flex-1 min-h-[44px] flex items-center justify-center border border-gray-300 rounded-lg hover:bg-gray-50"
    >
      取消
    </a>
  </div>
</form>

<script>
  import { createMilkRecord, updateMilkRecord } from '@/services/milk.service';
  import { getCows } from '@/services/cows.service';

  const form = document.getElementById('milk-record-form') as HTMLFormElement;
  const mode = form.dataset.mode || 'create';
  const recordId = form.dataset.recordId;

  // 如果是创建模式且没有预选奶牛，加载奶牛列表
  const cowSelect = document.getElementById('cow_id') as HTMLSelectElement;
  if (cowSelect) {
    (async () => {
      const { data: cows } = await getCows({ status: 'active' });
      if (cows) {
        // 只显示母牛
        const femaleCows = cows.filter(cow => cow.gender === 'female');
        femaleCows.forEach(cow => {
          const option = document.createElement('option');
          option.value = cow.id;
          option.textContent = `${cow.cow_number} - ${cow.name || '未命名'}`;
          cowSelect.appendChild(option);
        });
      }
    })();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data: any = {};
    
    formData.forEach((value, key) => {
      if (value !== '' && value !== null) {
        const numberFields = ['milk_yield', 'fat_percentage', 'protein_percentage', 'lactose_percentage', 'somatic_cell_count'];
        if (numberFields.includes(key)) {
          data[key] = Number(value);
        } else {
          data[key] = value;
        }
      }
    });

    // 添加挤奶人员ID (当前用户)
    data.milker_id = (await import('@/lib/supabase')).supabase.auth.getUser().then(r => r.data.user?.id);

    try {
      if (mode === 'create') {
        const result = await createMilkRecord(data);
        if (result.error) throw result.error;
        alert('产奶记录添加成功！');
        window.location.href = '/milk';
      } else {
        const result = await updateMilkRecord(recordId!, data);
        if (result.error) throw result.error;
        alert('产奶记录保存成功！');
        window.location.href = `/milk/${recordId}`;
      }
    } catch (error: any) {
      alert(`操作失败：${error.message}`);
    }
  });
</script>
