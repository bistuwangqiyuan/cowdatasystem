---
/**
 * Milk Record Form Component
 * 
 * 产奶记录表单组件，用于创建和编辑产奶记录。
 */

import type { MilkRecord } from '@/types/milk.types';
import { MILKING_SESSION_NAMES } from '@/types/milk.types';

interface Props {
  record?: MilkRecord;
  mode: 'create' | 'edit';
  cowId?: string;
}

const { record, mode, cowId } = Astro.props;
const isEdit = mode === 'edit';
---

<form id="milk-form" class="space-y-6">
  <!-- 奶牛ID -->
  <input type="hidden" name="cow_id" value={cowId || record?.cow_id || ''} />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 记录时间 -->
    <div>
      <label for="recorded_datetime" class="block text-sm font-medium text-gray-700 mb-2">
        记录时间 <span class="text-red-500">*</span>
      </label>
      <input
        type="datetime-local"
        id="recorded_datetime"
        name="recorded_datetime"
        value={record?.recorded_datetime ? new Date(record.recorded_datetime).toISOString().slice(0, 16) : ''}
        required
        max={new Date().toISOString().slice(0, 16)}
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
    </div>

    <!-- 班次 -->
    <div>
      <label for="session" class="block text-sm font-medium text-gray-700 mb-2">
        挤奶班次 <span class="text-red-500">*</span>
      </label>
      <select
        id="session"
        name="session"
        required
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      >
        <option value="">请选择班次</option>
        {Object.entries(MILKING_SESSION_NAMES).map(([value, label]) => (
          <option value={value} selected={record?.session === value}>
            {label}
          </option>
        ))}
      </select>
    </div>

    <!-- 产奶量 -->
    <div>
      <label for="amount" class="block text-sm font-medium text-gray-700 mb-2">
        产奶量 (升) <span class="text-red-500">*</span>
      </label>
      <input
        type="number"
        id="amount"
        name="amount"
        value={record?.amount || ''}
        required
        step="0.1"
        min="0"
        max="100"
        placeholder="例如: 25.5"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">正常范围: 15-40升</p>
    </div>

    <!-- 脂肪率 -->
    <div>
      <label for="fat_rate" class="block text-sm font-medium text-gray-700 mb-2">
        脂肪率 (%)
      </label>
      <input
        type="number"
        id="fat_rate"
        name="fat_rate"
        value={record?.fat_rate || ''}
        step="0.01"
        min="0"
        max="15"
        placeholder="例如: 3.8"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">正常范围: 3.0-5.0%</p>
    </div>

    <!-- 蛋白质率 -->
    <div>
      <label for="protein_rate" class="block text-sm font-medium text-gray-700 mb-2">
        蛋白质率 (%)
      </label>
      <input
        type="number"
        id="protein_rate"
        name="protein_rate"
        value={record?.protein_rate || ''}
        step="0.01"
        min="0"
        max="10"
        placeholder="例如: 3.2"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">正常范围: 2.8-3.5%</p>
    </div>

    <!-- 体细胞数 -->
    <div>
      <label for="somatic_cell_count" class="block text-sm font-medium text-gray-700 mb-2">
        体细胞数 (×1000/mL)
      </label>
      <input
        type="number"
        id="somatic_cell_count"
        name="somatic_cell_count"
        value={record?.somatic_cell_count || ''}
        step="1"
        min="0"
        placeholder="例如: 200"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">优质奶: &lt;200, 警戒: &gt;400</p>
    </div>
  </div>

  <!-- 错误提示 -->
  <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

  <!-- 按钮组 -->
  <div class="flex justify-end space-x-4 pt-4">
    <button
      type="button"
      id="cancel-btn"
      class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
    >
      取消
    </button>
    <button
      type="submit"
      id="submit-btn"
      class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
    >
      {isEdit ? '保存' : '创建'}
    </button>
  </div>
</form>

<script>
  import { createMilkRecord, updateMilkRecord } from '@/services/milk.service';
  import { validateMilkAmount, validateFatRate, validateProteinRate } from '@/lib/validation';
  
  const form = document.getElementById('milk-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('cancel-btn') as HTMLButtonElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  
  const urlParams = new URLSearchParams(window.location.search);
  const mode = urlParams.get('mode') || 'create';
  const recordId = urlParams.get('id');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    formError?.classList.add('hidden');
    
    const formData = new FormData(form);
    const data: any = {};
    
    formData.forEach((value, key) => {
      if (value !== '') {
        if (['amount', 'fat_rate', 'protein_rate'].includes(key)) {
          data[key] = parseFloat(value as string);
        } else if (key === 'somatic_cell_count') {
          data[key] = parseInt(value as string, 10);
        } else {
          data[key] = value;
        }
      }
    });
    
    // 验证
    const amountValidation = validateMilkAmount(data.amount);
    if (!amountValidation.isValid) {
      formError.textContent = amountValidation.error || '产奶量无效';
      formError.classList.remove('hidden');
      return;
    }
    
    if (data.fat_rate) {
      const fatValidation = validateFatRate(data.fat_rate);
      if (!fatValidation.isValid) {
        formError.textContent = fatValidation.error || '脂肪率无效';
        formError.classList.remove('hidden');
        return;
      }
    }
    
    if (data.protein_rate) {
      const proteinValidation = validateProteinRate(data.protein_rate);
      if (!proteinValidation.isValid) {
        formError.textContent = proteinValidation.error || '蛋白质率无效';
        formError.classList.remove('hidden');
        return;
      }
    }
    
    submitBtn.classList.add('loading');
    submitBtn.textContent = mode === 'edit' ? '保存中...' : '创建中...';
    
    try {
      let result;
      
      if (mode === 'edit' && recordId) {
        result = await updateMilkRecord(recordId, data);
      } else {
        result = await createMilkRecord(data);
      }
      
      if (result.error) {
        throw new Error(result.error.message || '操作失败');
      }
      
      const cowId = data.cow_id;
      window.location.href = cowId ? `/cows/${cowId}` : '/milk';
      
    } catch (error: any) {
      formError.textContent = error.message || '操作失败，请重试';
      formError.classList.remove('hidden');
      
      submitBtn.classList.remove('loading');
      submitBtn.textContent = mode === 'edit' ? '保存' : '创建';
    }
  });
  
  cancelBtn?.addEventListener('click', () => {
    const cowId = new URLSearchParams(window.location.search).get('cow_id');
    window.location.href = cowId ? `/cows/${cowId}` : '/milk';
  });
</script>

