---
/**
 * Cow Form Component
 * 
 * 奶牛信息表单组件，用于创建和编辑奶牛档案。
 * 支持数据验证和实时反馈。
 */

import type { Cow } from '@/types/cow.types';
import { BREED_NAMES, GENDER_NAMES, STATUS_NAMES } from '@/types/cow.types';

interface Props {
  cow?: Cow;
  mode: 'create' | 'edit';
}

const { cow, mode } = Astro.props;
const isEdit = mode === 'edit';
---

<form id="cow-form" class="space-y-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 奶牛编号 -->
    <div>
      <label for="cow_number" class="block text-sm font-medium text-gray-700 mb-2">
        奶牛编号 <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="cow_number"
        name="cow_number"
        value={cow?.cow_number || ''}
        required
        placeholder="例如: CN001"
        pattern="[A-Z0-9]{3,50}"
        title="3-50个大写字母或数字"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
        disabled={isEdit}
      />
      <p class="text-xs text-gray-500 mt-1">3-50个大写字母或数字</p>
    </div>

    <!-- 奶牛名称 -->
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
        奶牛名称
      </label>
      <input
        type="text"
        id="name"
        name="name"
        value={cow?.name || ''}
        placeholder="例如: 小花"
        maxlength="100"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
    </div>

    <!-- 品种 -->
    <div>
      <label for="breed" class="block text-sm font-medium text-gray-700 mb-2">
        品种 <span class="text-red-500">*</span>
      </label>
      <select
        id="breed"
        name="breed"
        required
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      >
        <option value="">请选择品种</option>
        {Object.entries(BREED_NAMES).map(([value, label]) => (
          <option value={value} selected={cow?.breed === value}>
            {label}
          </option>
        ))}
      </select>
    </div>

    <!-- 性别 -->
    <div>
      <label for="gender" class="block text-sm font-medium text-gray-700 mb-2">
        性别 <span class="text-red-500">*</span>
      </label>
      <select
        id="gender"
        name="gender"
        required
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      >
        <option value="">请选择性别</option>
        {Object.entries(GENDER_NAMES).map(([value, label]) => (
          <option value={value} selected={cow?.gender === value}>
            {label}
          </option>
        ))}
      </select>
    </div>

    <!-- 出生日期 -->
    <div>
      <label for="birth_date" class="block text-sm font-medium text-gray-700 mb-2">
        出生日期 <span class="text-red-500">*</span>
      </label>
      <input
        type="date"
        id="birth_date"
        name="birth_date"
        value={cow?.birth_date || ''}
        required
        max={new Date().toISOString().split('T')[0]}
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
    </div>

    <!-- 入栏日期 -->
    <div>
      <label for="entry_date" class="block text-sm font-medium text-gray-700 mb-2">
        入栏日期 <span class="text-red-500">*</span>
      </label>
      <input
        type="date"
        id="entry_date"
        name="entry_date"
        value={cow?.entry_date || ''}
        required
        max={new Date().toISOString().split('T')[0]}
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
    </div>

    <!-- 状态 (仅编辑模式) -->
    {isEdit && (
      <div>
        <label for="status" class="block text-sm font-medium text-gray-700 mb-2">
          状态 <span class="text-red-500">*</span>
        </label>
        <select
          id="status"
          name="status"
          required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
        >
          {Object.entries(STATUS_NAMES).map(([value, label]) => (
            <option value={value} selected={cow?.status === value}>
              {label}
            </option>
          ))}
        </select>
      </div>
    )}

    <!-- 父牛ID (可选) -->
    <div>
      <label for="sire_id" class="block text-sm font-medium text-gray-700 mb-2">
        父牛编号
      </label>
      <input
        type="text"
        id="sire_id"
        name="sire_id"
        value={cow?.sire_id || ''}
        placeholder="选填"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
    </div>

    <!-- 母牛ID (可选) -->
    <div>
      <label for="dam_id" class="block text-sm font-medium text-gray-700 mb-2">
        母牛编号
      </label>
      <input
        type="text"
        id="dam_id"
        name="dam_id"
        value={cow?.dam_id || ''}
        placeholder="选填"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
      />
    </div>
  </div>

  <!-- 备注 -->
  <div>
    <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
      备注
    </label>
    <textarea
      id="notes"
      name="notes"
      rows="4"
      placeholder="记录奶牛的特殊信息..."
      maxlength="500"
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all resize-none"
    >{cow?.notes || ''}</textarea>
    <p class="text-xs text-gray-500 mt-1">最多500字</p>
  </div>

  <!-- 错误提示 -->
  <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
    <!-- 错误信息 -->
  </div>

  <!-- 按钮组 -->
  <div class="flex justify-end space-x-4 pt-4">
    <button
      type="button"
      id="cancel-btn"
      class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
    >
      取消
    </button>
    <button
      type="submit"
      id="submit-btn"
      class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
    >
      {isEdit ? '保存' : '创建'}
    </button>
  </div>
</form>

<style>
  /* 移除数字输入框的spinner */
  input[type="date"]::-webkit-calendar-picker-indicator {
    cursor: pointer;
  }
  
  /* 加载状态 */
  .loading {
    opacity: 0.6;
    pointer-events: none;
  }
</style>

<script>
  import { createCow, updateCow } from '@/services/cows.service';
  import {
    validateCowNumber,
    validateBirthAndEntryDates,
    validateAll,
  } from '@/lib/validation';
  
  const form = document.getElementById('cow-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('cancel-btn') as HTMLButtonElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  
  // 获取模式（从data属性或URL参数）
  const urlParams = new URLSearchParams(window.location.search);
  const mode = form.dataset.mode || urlParams.get('mode') || 'create';
  const cowId = urlParams.get('id');
  
  // 表单提交处理
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // 隐藏错误提示
    formError?.classList.add('hidden');
    
    // 获取表单数据
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    // 客户端验证
    const cowNumber = data.cow_number as string;
    const birthDate = data.birth_date as string;
    const entryDate = data.entry_date as string;
    
    const validationResult = validateAll([
      () => validateCowNumber(cowNumber),
      () => validateBirthAndEntryDates(birthDate, entryDate),
    ]);
    
    if (!validationResult.isValid) {
      formError.textContent = validationResult.error || '数据验证失败';
      formError.classList.remove('hidden');
      return;
    }
    
    // 显示加载状态
    submitBtn.classList.add('loading');
    submitBtn.textContent = mode === 'edit' ? '保存中...' : '创建中...';
    
    try {
      let result;
      
      if (mode === 'edit' && cowId) {
        // 编辑模式
        result = await updateCow(cowId, data as any);
      } else {
        // 创建模式
        result = await createCow(data as any);
      }
      
      if (result.error) {
        throw new Error(result.error.message || '操作失败');
      }
      
      // 成功，跳转到列表页
      console.log('[CowForm] Success:', result.data);
      window.location.href = '/cows';
      
    } catch (error: any) {
      // 显示错误信息
      console.error('[CowForm] Error:', error);
      formError.textContent = error.message || '操作失败，请重试';
      formError.classList.remove('hidden');
      
      // 恢复按钮状态
      submitBtn.classList.remove('loading');
      submitBtn.textContent = mode === 'edit' ? '保存' : '创建';
    }
  });
  
  // 取消按钮
  cancelBtn?.addEventListener('click', () => {
    window.location.href = '/cows';
  });
  
  // 日期验证：entry_date >= birth_date
  const birthDateInput = document.getElementById('birth_date') as HTMLInputElement;
  const entryDateInput = document.getElementById('entry_date') as HTMLInputElement;
  
  function validateDates() {
    const birthDate = new Date(birthDateInput.value);
    const entryDate = new Date(entryDateInput.value);
    
    if (birthDate && entryDate && birthDate > entryDate) {
      entryDateInput.setCustomValidity('入栏日期不能早于出生日期');
    } else {
      entryDateInput.setCustomValidity('');
    }
  }
  
  birthDateInput?.addEventListener('change', validateDates);
  entryDateInput?.addEventListener('change', validateDates);
</script>

