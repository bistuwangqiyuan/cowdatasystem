---
/**
 * 健康记录表单组件
 * 用于创建和编辑健康记录
 */
import type { HealthRecord } from '@/types/health.types';

interface Props {
  record?: HealthRecord;
  cowId?: string;
  mode: 'create' | 'edit';
}

const { record, cowId, mode } = Astro.props;
---

<form id="health-record-form" class="space-y-4">
  <!-- 奶牛选择 (仅创建模式显示) -->
  {mode === 'create' && !cowId && (
    <div>
      <label for="cow_id" class="block text-sm font-medium mb-1">
        选择奶牛 <span class="text-red-500">*</span>
      </label>
      <select
        id="cow_id"
        name="cow_id"
        required
        class="w-full h-12 px-4 border rounded-lg"
      >
        <option value="">请选择奶牛</option>
        <!-- 奶牛列表将通过JavaScript动态加载 -->
      </select>
    </div>
  )}

  {(cowId || mode === 'edit') && (
    <input 
      type="hidden" 
      name="cow_id" 
      value={cowId || record?.cow_id} 
    />
  )}

  <!-- 检查日期时间 -->
  <div>
    <label for="check_datetime" class="block text-sm font-medium mb-1">
      检查时间 <span class="text-red-500">*</span>
    </label>
    <input
      type="datetime-local"
      id="check_datetime"
      name="check_datetime"
      value={record?.check_datetime?.slice(0, 16) || ''}
      max={new Date().toISOString().slice(0, 16)}
      required
      class="w-full h-12 px-4 border rounded-lg"
    />
  </div>

  <!-- 体温 -->
  <div>
    <label for="temperature" class="block text-sm font-medium mb-1">
      体温 (°C) <span class="text-red-500">*</span>
    </label>
    <input
      type="number"
      id="temperature"
      name="temperature"
      value={record?.temperature || ''}
      step="0.1"
      min="35.0"
      max="45.0"
      required
      class="w-full h-12 px-4 border rounded-lg"
      placeholder="正常范围: 38.0-39.5"
    />
    <p class="text-xs text-gray-500 mt-1">正常范围: 38.0-39.5°C</p>
  </div>

  <!-- 精神状态 -->
  <div>
    <label class="block text-sm font-medium mb-1">
      精神状态 <span class="text-red-500">*</span>
    </label>
    <div class="flex gap-4">
      <label class="flex items-center">
        <input
          type="radio"
          name="mental_state"
          value="normal"
          checked={record?.mental_state === 'normal' || !record}
          required
          class="mr-2 w-5 h-5"
        />
        正常
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="mental_state"
          value="depressed"
          checked={record?.mental_state === 'depressed'}
          class="mr-2 w-5 h-5"
        />
        沉郁
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="mental_state"
          value="excited"
          checked={record?.mental_state === 'excited'}
          class="mr-2 w-5 h-5"
        />
        兴奋
      </label>
    </div>
  </div>

  <!-- 食欲 -->
  <div>
    <label class="block text-sm font-medium mb-1">
      食欲 <span class="text-red-500">*</span>
    </label>
    <div class="flex gap-4">
      <label class="flex items-center">
        <input
          type="radio"
          name="appetite"
          value="good"
          checked={record?.appetite === 'good' || !record}
          required
          class="mr-2 w-5 h-5"
        />
        良好
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="appetite"
          value="normal"
          checked={record?.appetite === 'normal'}
          class="mr-2 w-5 h-5"
        />
        一般
      </label>
      <label class="flex items-center">
        <input
          type="radio"
          name="appetite"
          value="poor"
          checked={record?.appetite === 'poor'}
          class="mr-2 w-5 h-5"
        />
        较差
      </label>
    </div>
  </div>

  <!-- 可选生理指标 -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- 呼吸频率 -->
    <div>
      <label for="respiratory_rate" class="block text-sm font-medium mb-1">
        呼吸频率 (次/分)
      </label>
      <input
        type="number"
        id="respiratory_rate"
        name="respiratory_rate"
        value={record?.respiratory_rate || ''}
        min="0"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 15-35"
      />
    </div>

    <!-- 心率 -->
    <div>
      <label for="heart_rate" class="block text-sm font-medium mb-1">
        心率 (次/分)
      </label>
      <input
        type="number"
        id="heart_rate"
        name="heart_rate"
        value={record?.heart_rate || ''}
        min="0"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 60-80"
      />
    </div>

    <!-- 瘤胃蠕动频率 -->
    <div class="md:col-span-2">
      <label for="rumen_movement" class="block text-sm font-medium mb-1">
        瘤胃蠕动频率 (次/2分钟)
      </label>
      <input
        type="number"
        id="rumen_movement"
        name="rumen_movement"
        value={record?.rumen_movement || ''}
        min="0"
        class="w-full h-12 px-4 border rounded-lg"
        placeholder="正常: 4-10"
      />
    </div>
  </div>

  <!-- 粪便性状 -->
  <div>
    <label for="fecal_condition" class="block text-sm font-medium mb-1">
      粪便性状
    </label>
    <input
      type="text"
      id="fecal_condition"
      name="fecal_condition"
      value={record?.fecal_condition || ''}
      class="w-full h-12 px-4 border rounded-lg"
      placeholder="例如：正常、稀软、干硬"
    />
  </div>

  <!-- 健康问题 -->
  <div>
    <label for="health_issues" class="block text-sm font-medium mb-1">
      健康问题
    </label>
    <textarea
      id="health_issues"
      name="health_issues"
      rows="3"
      class="w-full px-4 py-2 border rounded-lg"
      placeholder="记录发现的健康问题..."
    >{record?.health_issues || ''}</textarea>
  </div>

  <!-- 处理措施 -->
  <div>
    <label for="treatment" class="block text-sm font-medium mb-1">
      处理措施
    </label>
    <textarea
      id="treatment"
      name="treatment"
      rows="3"
      class="w-full px-4 py-2 border rounded-lg"
      placeholder="采取的处理措施..."
    >{record?.treatment || ''}</textarea>
  </div>

  <!-- 备注 -->
  <div>
    <label for="notes" class="block text-sm font-medium mb-1">
      备注
    </label>
    <textarea
      id="notes"
      name="notes"
      rows="2"
      class="w-full px-4 py-2 border rounded-lg"
      placeholder="其他补充信息..."
    >{record?.notes || ''}</textarea>
  </div>

  <!-- 提交按钮 -->
  <div class="flex gap-4">
    <button
      type="submit"
      class="flex-1 min-h-[44px] bg-blue-600 text-white rounded-lg hover:bg-blue-700"
    >
      {mode === 'create' ? '添加记录' : '保存修改'}
    </button>
    <a
      href="/health"
      class="flex-1 min-h-[44px] flex items-center justify-center border border-gray-300 rounded-lg hover:bg-gray-50"
    >
      取消
    </a>
  </div>
</form>

<script>
  import { createHealthRecord, updateHealthRecord } from '@/services/health.service';
  import { getCows } from '@/services/cows.service';

  const form = document.getElementById('health-record-form') as HTMLFormElement;
  const mode = form.dataset.mode || 'create';
  const recordId = form.dataset.recordId;

  // 如果是创建模式且没有预选奶牛，加载奶牛列表
  const cowSelect = document.getElementById('cow_id') as HTMLSelectElement;
  if (cowSelect) {
    (async () => {
      const { data: cows } = await getCows();
      if (cows) {
        cows.forEach(cow => {
          const option = document.createElement('option');
          option.value = cow.id;
          option.textContent = `${cow.cow_number} - ${cow.name || '未命名'}`;
          cowSelect.appendChild(option);
        });
      }
    })();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data: any = {};
    
    formData.forEach((value, key) => {
      if (value !== '' && value !== null) {
        if (key === 'temperature' || key === 'respiratory_rate' || key === 'heart_rate' || key === 'rumen_movement') {
          data[key] = Number(value);
        } else {
          data[key] = value;
        }
      }
    });

    // 添加检查人员ID (当前用户)
    data.examiner_id = (await import('@/lib/supabase')).supabase.auth.getUser().then(r => r.data.user?.id);

    try {
      if (mode === 'create') {
        const result = await createHealthRecord(data);
        if (result.error) throw result.error;
        alert('健康记录添加成功！');
        window.location.href = '/health';
      } else {
        const result = await updateHealthRecord(recordId!, data);
        if (result.error) throw result.error;
        alert('健康记录保存成功！');
        window.location.href = `/health/${recordId}`;
      }
    } catch (error: any) {
      alert(`操作失败：${error.message}`);
    }
  });
</script>
