---
/**
 * Health Record Form Component
 * 
 * 健康记录表单组件，用于创建和编辑健康记录。
 */

import type { HealthRecord } from '@/types/health.types';
import { HEALTH_STATUS_NAMES } from '@/types/health.types';

interface Props {
  record?: HealthRecord;
  mode: 'create' | 'edit';
  cowId?: string;
}

const { record, mode, cowId } = Astro.props;
const isEdit = mode === 'edit';
---

<form id="health-form" class="space-y-6">
  <!-- 奶牛ID（隐藏字段或只读） -->
  <input type="hidden" name="cow_id" value={cowId || record?.cow_id || ''} />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 记录日期 -->
    <div>
      <label for="recorded_date" class="block text-sm font-medium text-gray-700 mb-2">
        记录日期 <span class="text-red-500">*</span>
      </label>
      <input
        type="date"
        id="recorded_date"
        name="recorded_date"
        value={record?.recorded_date || new Date().toISOString().split('T')[0]}
        required
        max={new Date().toISOString().split('T')[0]}
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
    </div>

    <!-- 体温 -->
    <div>
      <label for="temperature" class="block text-sm font-medium text-gray-700 mb-2">
        体温 (°C)
      </label>
      <input
        type="number"
        id="temperature"
        name="temperature"
        value={record?.temperature || ''}
        step="0.1"
        min="35"
        max="45"
        placeholder="例如: 38.5"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
      <p class="text-xs text-gray-500 mt-1">正常范围: 37.5-39.5°C</p>
    </div>

    <!-- 精神状态 -->
    <div>
      <label for="mental_status" class="block text-sm font-medium text-gray-700 mb-2">
        精神状态
      </label>
      <select
        id="mental_status"
        name="mental_status"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      >
        <option value="">请选择</option>
        {Object.entries(HEALTH_STATUS_NAMES).map(([value, label]) => (
          <option value={value} selected={record?.mental_status === value}>
            {label}
          </option>
        ))}
      </select>
    </div>

    <!-- 食欲 -->
    <div>
      <label for="appetite" class="block text-sm font-medium text-gray-700 mb-2">
        食欲
      </label>
      <select
        id="appetite"
        name="appetite"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      >
        <option value="">请选择</option>
        {Object.entries(HEALTH_STATUS_NAMES).map(([value, label]) => (
          <option value={value} selected={record?.appetite === value}>
            {label}
          </option>
        ))}
      </select>
    </div>

    <!-- 粪便状况 -->
    <div class="md:col-span-2">
      <label for="fecal_condition" class="block text-sm font-medium text-gray-700 mb-2">
        粪便状况
      </label>
      <input
        type="text"
        id="fecal_condition"
        name="fecal_condition"
        value={record?.fecal_condition || ''}
        placeholder="例如: 正常、偏干、偏稀等"
        maxlength="200"
        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"
      />
    </div>
  </div>

  <!-- 症状 -->
  <div>
    <label for="symptoms" class="block text-sm font-medium text-gray-700 mb-2">
      症状描述
    </label>
    <textarea
      id="symptoms"
      name="symptoms"
      rows="4"
      placeholder="记录观察到的异常症状..."
      maxlength="1000"
      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none"
    >{record?.symptoms || ''}</textarea>
    <p class="text-xs text-gray-500 mt-1">最多1000字</p>
  </div>

  <!-- 错误提示 -->
  <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>

  <!-- 按钮组 -->
  <div class="flex justify-end space-x-4 pt-4">
    <button
      type="button"
      id="cancel-btn"
      class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors"
    >
      取消
    </button>
    <button
      type="submit"
      id="submit-btn"
      class="px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
    >
      {isEdit ? '保存' : '创建'}
    </button>
  </div>
</form>

<script>
  import { createHealthRecord, updateHealthRecord } from '@/services/health.service';
  import { validateDate, validateTemperature } from '@/lib/validation';
  
  const form = document.getElementById('health-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('cancel-btn') as HTMLButtonElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;
  
  const urlParams = new URLSearchParams(window.location.search);
  const mode = urlParams.get('mode') || 'create';
  const recordId = urlParams.get('id');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    formError?.classList.add('hidden');
    
    const formData = new FormData(form);
    const data: any = {};
    
    formData.forEach((value, key) => {
      if (value !== '') {
        if (key === 'temperature') {
          data[key] = parseFloat(value as string);
        } else {
          data[key] = value;
        }
      }
    });
    
    // 验证
    if (data.temperature) {
      const tempValidation = validateTemperature(data.temperature);
      if (!tempValidation.isValid) {
        formError.textContent = tempValidation.error || '体温数据无效';
        formError.classList.remove('hidden');
        return;
      }
    }
    
    submitBtn.classList.add('loading');
    submitBtn.textContent = mode === 'edit' ? '保存中...' : '创建中...';
    
    try {
      let result;
      
      if (mode === 'edit' && recordId) {
        result = await updateHealthRecord(recordId, data);
      } else {
        result = await createHealthRecord(data);
      }
      
      if (result.error) {
        throw new Error(result.error.message || '操作失败');
      }
      
      const cowId = data.cow_id;
      window.location.href = cowId ? `/cows/${cowId}` : '/health';
      
    } catch (error: any) {
      formError.textContent = error.message || '操作失败，请重试';
      formError.classList.remove('hidden');
      
      submitBtn.classList.remove('loading');
      submitBtn.textContent = mode === 'edit' ? '保存' : '创建';
    }
  });
  
  cancelBtn?.addEventListener('click', () => {
    const cowId = new URLSearchParams(window.location.search).get('cow_id');
    window.location.href = cowId ? `/cows/${cowId}` : '/health';
  });
</script>

